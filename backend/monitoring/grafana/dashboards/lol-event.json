{
  "title": "LoL Event - 서비스 모니터링",
  "uid": "lol-event-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(jvm_memory_used_bytes, instance)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": {},
        "label": "Instance"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP 요청 처리량 (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{instance=~\"$instance\"}[1m])) by (instance)",
          "legendFormat": "{{instance}} - total",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{instance=~\"$instance\", status=~\"2..\"}[1m])) by (instance)",
          "legendFormat": "{{instance}} - 2xx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "에러율 (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{instance=~\"$instance\", status=~\"5..\"}[1m])) by (instance)",
          "legendFormat": "{{instance}} 5xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{instance=~\"$instance\", status=~\"4..\"}[1m])) by (instance)",
          "legendFormat": "{{instance}} 4xx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "응답 지연 P99 / P95 / P50",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{instance=~\"$instance\"}[1m])) by (le, instance))",
          "legendFormat": "{{instance}} p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{instance=~\"$instance\"}[1m])) by (le, instance))",
          "legendFormat": "{{instance}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{instance=~\"$instance\"}[1m])) by (le, instance))",
          "legendFormat": "{{instance}} p50",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "예외 발생 수 (유형별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(app_errors_total{instance=~\"$instance\"}[5m])) by (type, instance)",
          "legendFormat": "{{instance}} - {{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "JVM 힙 메모리 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{instance=~\"$instance\", area=\"heap\"}",
          "legendFormat": "{{instance}} used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{instance=~\"$instance\", area=\"heap\"}",
          "legendFormat": "{{instance}} max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM 스레드 수",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} daemon",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "DB 커넥션 풀 (HikariCP)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} pending",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Endpoint별 요청 처리량 (Top 10)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_server_requests_seconds_count{instance=~\"$instance\"}[1m])) by (uri, method))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "요청 처리량 현재값",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 32 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{instance=~\"$instance\"}[1m]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "5xx 에러 (1m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 32 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_seconds_count{instance=~\"$instance\", status=~\"5..\"}[1m])) or vector(0)",
          "legendFormat": "5xx",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "JVM CPU 사용률",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 32 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{instance=~\"$instance\"}",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "업타임",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 32 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "process_uptime_seconds{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    }
  ]
}
