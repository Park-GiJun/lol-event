{
  "title": "LoL Event - 로그 모니터링",
  "uid": "lol-event-logs",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(container)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "current": {},
        "label": "Service"
      },
      {
        "name": "level",
        "type": "custom",
        "query": "ERROR,WARN,INFO,DEBUG",
        "includeAll": true,
        "allValue": ".*",
        "current": {},
        "label": "Log Level"
      },
      {
        "name": "search",
        "type": "textbox",
        "current": { "value": "" },
        "label": "Search"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "로그 볼륨",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 50,
            "drawStyle": "bars",
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |~ \"$search\" [1m])) by (container)",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 2,
      "title": "에러 로그 추이",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |~ \"(?i)(ERROR|error|Exception|exception)\" [1m])) by (container)",
          "legendFormat": "{{container}} errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "레벨별 로그 분포",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |~ \"ERROR\" [$__range])) ",
          "legendFormat": "ERROR",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |~ \"WARN\" [$__range]))",
          "legendFormat": "WARN",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |~ \"INFO\" [$__range]))",
          "legendFormat": "INFO",
          "refId": "C"
        },
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |~ \"DEBUG\" [$__range]))",
          "legendFormat": "DEBUG",
          "refId": "D"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "id": 4,
      "title": "서비스별 로그 수 (1분)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "datasource": "Loki",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$service\"}[1m])) by (container)",
          "legendFormat": "{{container}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "로그 스트림 - 전체 서비스",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 12 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{container=~\"$service\"} |~ \"(?i)$level\" |~ \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
