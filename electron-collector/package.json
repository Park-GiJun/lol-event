{
  "name": "lol-collector",
  "version": "1.0.8",
  "description": "LoL 내전 데이터 수집기",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "electron-vite build && electron-builder --win --publish=never"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-updater": "^6.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "lucide-react": "^0.469.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "net.gijun.lol-collector",
    "productName": "LoL 수집기",
    "directories": { "output": "../installer" },
    "files": ["out/**", "assets/**"],
    "extraResources": [{ "from": "assets", "to": "assets" }],
    "publish": {
      "provider": "generic",
      "url": "https://gijun.net/downloads/"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "lol-collector-setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LoL 수집기"
    }
  }
}
