{
  "name": "lol-collector",
  "version": "1.0.3",
  "description": "LoL 내전 데이터 수집기",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && electron .",
    "dist:win": "tsc && electron-builder --win --publish=never"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "net.gijun.lol-collector",
    "productName": "LoL 수집기",
    "directories": {
      "output": "../installer"
    },
    "files": [
      "dist/**/*",
      "renderer/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      { "from": "assets", "to": "assets" }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://gijun.net/downloads/"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "lol-collector-setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "LoL 수집기"
    }
  }
}
